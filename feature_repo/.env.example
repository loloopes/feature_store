# Copy to .env and adjust for your MinIO instance.
FEAST_S3_ENDPOINT_URL=http://localhost:19000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_EC2_METADATA_DISABLED=true

# DVC remote (optional; default s3://feast/dvc-storage)
# DVC_REMOTE_URL=s3://feast/dvc-storage
